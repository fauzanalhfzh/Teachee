# Database
DATABASE_URL=postgresql://postgres:password123@db:5432/quiz_db

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256

# Seeding
SEED_PASSWORD=password123

# AI / vLLM (OpenAI-compatible server, e.g. DigitalOcean vLLM 1-Click droplet)
# Pastikan container vLLM (mis. "rocm") sudah terhubung ke network "teachee-vllm"
# dan vLLM server sudah jalan: vllm serve <model> --host 0.0.0.0 --port 8000
AI_PROVIDER=vllm
VLLM_URL=http://rocm:8000/v1
VLLM_MODEL=Qwen3-30B-A3B
VLLM_TIMEOUT=60
# VLLM_API_KEY=   # isi hanya jika vLLM dijalankan dengan --api-key
